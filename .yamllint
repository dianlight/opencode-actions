# yamllint configuration for GitHub Actions workflows and config files
extends: default

rules:
  document-start:
    present: false  # GitHub workflows don't require ---
  line-length:
    max: 180        # Allow longer lines for workflow expressions
    level: warning
  comments:
    min-spaces-from-content: 1  # Allow 1 space before comments
  brackets:
    max-spaces-inside: 1
  indentation:
    spaces: 2
    indent-sequences: consistent
  truthy:
    level: warning  # `on:` in GitHub workflows triggers false positives
    check-keys: false

# Ignore files that are not YAML
ignore: |
  .git/
  node_modules/
  __pycache__/
  scripts/__pycache__/
  data/*.json